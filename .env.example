# ============================================================
# Portal de Relatórios WMI — variáveis de ambiente
# Copie para .env (NÃO commitado) e preencha com valores reais.
#   cp .env.example .env
# No Coolify, defina cada variável como Secret no painel do app.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=relatorios
POSTGRES_USER=wmi
POSTGRES_PASSWORD=troque-esta-senha

# ── MinIO (object storage) ──────────────────────────────────
MINIO_ROOT_USER=troque-este-usuario
MINIO_ROOT_PASSWORD=troque-esta-senha-forte

# ── Backend ─────────────────────────────────────────────────
# Origem do frontend liberada no CORS (acesso direto em dev). Nunca use "*".
FRONTEND_URL=http://localhost:3000
# "development" habilita o fallback de identidade sem o proxy SSO na frente.
# Em produção (Coolify) deixe "production".
APP_ENV=development
# E-mail usado como usuário logado quando APP_ENV=development (sem SSO local).
DEV_USER_EMAIL=seu.email@wmi.solutions
# E-mails (separados por vírgula) que recebem papel admin automaticamente.
ADMIN_EMAILS=seu.email@wmi.solutions
# Tamanho máximo por arquivo enviado (MB).
MAX_UPLOAD_MB=50
# Segredo compartilhado entre o nginx do frontend e o backend (defesa em profundidade).
# Se definido, o backend recusa requests que não venham pelo frontend. Gere um valor
# aleatório forte em produção (ex.: openssl rand -hex 32). Deixe vazio só em dev.
INTERNAL_PROXY_SECRET=

# ── Frontend (nginx reverse-proxy → backend) ────────────────
# Endereço interno do backend. Local (compose): http://backend:8000
# Coolify: hostname interno do app de backend (ex.: http://relatorios-api:8000)
API_UPSTREAM=http://backend:8000
